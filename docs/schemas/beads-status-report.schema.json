{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/beads-status-report.schema.json",
  "title": "ADLC Beads Status Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "status",
    "workspace",
    "bd_present",
    "beads_dir_present",
    "safe_to_use",
    "checks",
    "warnings",
    "summary"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "status": {
      "type": "string",
      "enum": ["available", "not_configured", "unavailable"]
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "bd_present": {
      "type": "boolean"
    },
    "bd_path": {
      "type": ["string", "null"]
    },
    "bd_version": {
      "type": ["string", "null"]
    },
    "beads_dir_present": {
      "type": "boolean"
    },
    "beads_dir": {
      "type": ["string", "null"]
    },
    "safe_to_use": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "status", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["pass", "warn", "absent"]},
          "detail": {"type": "string"}
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["total", "warnings"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "warnings": {"type": "integer", "minimum": 0}
      }
    }
  }
}
