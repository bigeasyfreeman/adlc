{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/permission-audit-trail.schema.json",
  "title": "ADLC Permission Audit Trail",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "brief_id",
    "entries",
    "denial_summary"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "tool_name",
          "action",
          "tier",
          "decision",
          "reason",
          "decided_by",
          "timestamp",
          "session_id",
          "brief_id"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "enum": [
              "unrestricted",
              "requires_approval",
              "requires_escalation"
            ]
          },
          "decision": {
            "type": "string",
            "enum": [
              "approved",
              "denied"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "decided_by": {
            "type": "string",
            "enum": [
              "human",
              "machine",
              "policy"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "brief_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "denial_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "patterns"
      ],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "export_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "json",
          "markdown"
        ]
      },
      "default": [
        "json",
        "markdown"
      ]
    }
  }
}
