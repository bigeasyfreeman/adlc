{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/token-budget.schema.json",
  "title": "ADLC Token Budget",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "budget_limit",
    "tokens_used",
    "tokens_by_phase",
    "tokens_by_skill",
    "cost_estimate",
    "thresholds"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "budget_limit": {
      "type": "integer",
      "minimum": 1
    },
    "tokens_used": {
      "type": "integer",
      "minimum": 0
    },
    "tokens_by_phase": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "phase_0_codebase_research",
          "phase_0a_grafana_observability",
          "phase_1_brief_prefill",
          "phase_2_eval_council",
          "phase_3_scaffolding",
          "phase_4_failing_tests",
          "phase_5_codegen_context",
          "phase_6_parallel_codegen",
          "phase_7_security_review",
          "phase_8_task_breakdown",
          "phase_9_codegen_execution",
          "phase_10_jira_confluence_prep",
          "phase_11_ci_cd_qa_prep",
          "phase_12_deploy_gate",
          "phase_13_monitoring_feedback"
        ]
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "tokens_by_skill": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "cost_estimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "total",
        "by_model"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "enum": [
            "USD"
          ]
        },
        "total": {
          "type": "number",
          "minimum": 0
        },
        "by_model": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "input_tokens",
              "output_tokens",
              "estimated_cost"
            ],
            "properties": {
              "input_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "output_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "estimated_cost": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warn_at",
        "alert_at",
        "hard_stop_at"
      ],
      "properties": {
        "warn_at": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "alert_at": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.8
        },
        "hard_stop_at": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "warning",
        "alert",
        "exhausted"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
