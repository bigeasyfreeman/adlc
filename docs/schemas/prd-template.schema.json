{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/prd-template.schema.json",
  "title": "ADLC PRD Template Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "metadata",
    "sections",
    "machine_parsed_sections"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prd_id",
        "title",
        "owner",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "prd_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem_statement",
        "goals",
        "non_goals",
        "personas",
        "user_flows",
        "requirements",
        "acceptance_criteria",
        "traffic_and_load_expectations",
        "technology_considerations",
        "engineering_architecture_input",
        "rollout_plan",
        "risks_and_mitigations",
        "open_questions"
      ],
      "properties": {
        "problem_statement": {
          "type": "string",
          "minLength": 1
        },
        "goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "personas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "needs"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "needs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "user_flows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "traffic_and_load_expectations": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "baseline_rps",
            "peak_rps",
            "latency_slo_ms"
          ],
          "properties": {
            "baseline_rps": {
              "type": "number",
              "minimum": 0
            },
            "peak_rps": {
              "type": "number",
              "minimum": 0
            },
            "latency_slo_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "technology_considerations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "engineering_architecture_input": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rollout_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks_and_mitigations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "risk",
              "mitigation"
            ],
            "properties": {
              "risk": {
                "type": "string"
              },
              "mitigation": {
                "type": "string"
              }
            }
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "machine_parsed_sections": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "problem_statement",
          "goals",
          "non_goals",
          "requirements",
          "acceptance_criteria",
          "traffic_and_load_expectations",
          "technology_considerations",
          "engineering_architecture_input"
        ]
      },
      "minItems": 1
    }
  }
}
