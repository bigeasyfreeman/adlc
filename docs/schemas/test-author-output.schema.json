{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/test-author-output.schema.json",
  "title": "ADLC Test Author Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "label",
    "task_id",
    "generated_tests",
    "pre_change_run_path",
    "verifier_target_intersection",
    "self_check"
  ],
  "properties": {
    "label": {
      "type": "string",
      "enum": ["done", "stuck", "revise"]
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ac_id",
          "test_path",
          "test_name",
          "expected_pre_change_failure_reason",
          "assertion_count"
        ],
        "properties": {
          "ac_id": {
            "type": "string",
            "pattern": "^AC-[A-Z0-9_-]+$"
          },
          "test_path": {
            "type": "string",
            "minLength": 1
          },
          "test_name": {
            "type": "string",
            "minLength": 1
          },
          "expected_pre_change_failure_reason": {
            "type": "string",
            "minLength": 1
          },
          "assertion_count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "pre_change_run_path": {
      "type": "string",
      "const": ".adlc/pre_change_run.txt"
    },
    "verifier_target_intersection": {
      "type": "boolean"
    },
    "self_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_1",
        "gate_2",
        "gate_3",
        "gate_4",
        "gate_5",
        "gate_6"
      ],
      "properties": {
        "gate_1": { "type": "string", "enum": ["pass", "fail"] },
        "gate_2": { "type": "string", "enum": ["pass", "fail"] },
        "gate_3": { "type": "string", "enum": ["pass", "fail"] },
        "gate_4": { "type": "string", "enum": ["pass", "fail"] },
        "gate_5": { "type": "string", "enum": ["pass", "fail"] },
        "gate_6": { "type": "string", "enum": ["pass", "fail"] }
      }
    },
    "reason": {
      "type": ["string", "null"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "label": {
            "const": "done"
          }
        }
      },
      "then": {
        "properties": {
          "generated_tests": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
