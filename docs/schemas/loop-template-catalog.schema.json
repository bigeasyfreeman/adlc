{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/loop-template-catalog.schema.json",
  "title": "ADLC Loop Template Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "catalog_id",
    "updated_at",
    "templates"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "catalog_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/template"
      }
    }
  },
  "definitions": {
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id",
        "title",
        "summary",
        "category",
        "autonomy_claim",
        "job",
        "exit_gate",
        "task_signals",
        "required_skills",
        "connectors",
        "required_adlc_commands",
        "required_schemas",
        "tools",
        "feedback_channels",
        "stop_escalate_rules",
        "mandatory_floor",
        "required_from_task_signals",
        "safe_bail_state",
        "progress_signal",
        "control_channel",
        "independent_truth",
        "redaction_posture",
        "gates",
        "human_approval_points",
        "queue_seed_tasks",
        "runbook",
        "no_overclaim"
      ],
      "properties": {
        "template_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": ["ci", "pr", "dependency", "tracker", "architecture", "feedback", "learning"]
        },
        "autonomy_claim": {
          "type": "string",
          "enum": ["one_shot", "assisted_loop", "self_autonomous"]
        },
        "job": {
          "type": "string",
          "minLength": 1
        },
        "exit_gate": {
          "type": "string",
          "minLength": 1
        },
        "semantic_intent_check": {
          "type": "string",
          "minLength": 1
        },
        "task_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_skills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path", "purpose"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "purpose": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "connectors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_adlc_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_schemas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/tool"
          }
        },
        "feedback_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["after_action", "observes"],
            "properties": {
              "after_action": {
                "type": "string",
                "minLength": 1
              },
              "observes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "stop_escalate_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_iterations", "no_progress_after", "escalate_when"],
          "properties": {
            "max_iterations": {
              "type": "integer",
              "minimum": 1
            },
            "no_progress_after": {
              "type": "integer",
              "minimum": 1
            },
            "escalate_when": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "mandatory_floor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/required_test"
          }
        },
        "required_from_task_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/required_test"
          }
        },
        "safe_bail_state": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "rollback", "idempotency"],
          "properties": {
            "state": {
              "type": "string",
              "minLength": 1
            },
            "rollback": {
              "type": "string",
              "minLength": 1
            },
            "idempotency": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "progress_signal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["signals", "no_progress_rule"],
          "properties": {
            "signals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "no_progress_rule": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "control_channel": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supports", "safe_checkpoint_required"],
          "properties": {
            "supports": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["steer", "abort", "interrupt", "escalate"]
              }
            },
            "safe_checkpoint_required": {
              "type": "boolean"
            }
          }
        },
        "independent_truth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "evidence"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["golden_fixture", "external_command", "schema", "mutation", "agent_self_assessment"]
            },
            "evidence": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "redaction_posture": {
          "type": "string",
          "minLength": 1
        },
        "budget_guard": {
          "type": "object"
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate_id", "type", "command", "failure_action"],
            "properties": {
              "gate_id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["schema_validation", "deterministic_verifier", "action_admission", "budget_guard", "human_review", "memory_health", "holdout_promotion"]
              },
              "command": {
                "type": "string",
                "minLength": 1
              },
              "failure_action": {
                "type": "string",
                "enum": ["block", "escalate", "retry_once", "human_review"]
              }
            }
          }
        },
        "human_approval_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "queue_seed_tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/queue_seed_task"
          }
        },
        "runbook": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "no_overclaim": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "actions",
        "side_effect_profile",
        "permission_tier",
        "available_phases"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["observe", "run_tool", "run_tests", "repair", "replan", "steer", "abort", "escalate"]
          }
        },
        "side_effect_profile": {
          "type": "string",
          "enum": ["read_only", "mutating", "destructive"]
        },
        "permission_tier": {
          "type": "string",
          "enum": ["unrestricted", "requires_approval", "requires_escalation"]
        },
        "available_phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "required_test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command", "coverage_tags"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "signal": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "coverage_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "queue_seed_task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "title", "source_ref", "expected_paths", "verifier_refs", "evidence_required"],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "expected_paths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "kind"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "enum": ["file", "directory", "glob"]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "verifier_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_required": {
          "type": "boolean"
        }
      }
    }
  }
}
