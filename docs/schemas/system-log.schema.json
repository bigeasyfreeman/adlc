{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/system-log.schema.json",
  "title": "ADLC System Log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "entries"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "timestamp",
          "session_id",
          "message",
          "metadata"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "initialization",
              "tool_selection",
              "permission_decision",
              "council_evaluation",
              "skill_execution",
              "error",
              "persistence",
              "budget"
            ]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "session_id": {
            "type": "string"
          },
          "brief_id": {
            "type": "string"
          },
          "phase": {
            "type": "string",
            "enum": [
              "phase_0_codebase_research",
              "phase_0a_grafana_observability",
              "phase_1_brief_prefill",
              "phase_2_eval_council",
              "phase_3_scaffolding",
              "phase_4_failing_tests",
              "phase_5_codegen_context",
              "phase_6_parallel_codegen",
              "phase_7_security_review",
              "phase_8_task_breakdown",
              "phase_9_codegen_execution",
              "phase_10_jira_confluence_prep",
              "phase_11_ci_cd_qa_prep",
              "phase_12_deploy_gate",
              "phase_13_monitoring_feedback"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
