{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/loop-contract.schema.json",
  "title": "ADLC Loop Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "contract_id",
    "autonomy_claim",
    "job_win_condition",
    "allowed_tools",
    "feedback_channels",
    "stop_escalate_rules",
    "test_selection",
    "safe_bail_state",
    "progress_signal",
    "control_channel",
    "independent_truth",
    "redaction_posture"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "autonomy_claim": {
      "type": "string",
      "enum": ["one_shot", "assisted_loop", "self_autonomous"]
    },
    "job_win_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job", "done_when", "deterministic_checks"],
      "properties": {
        "job": {
          "type": "string",
          "minLength": 1
        },
        "done_when": {
          "type": "string",
          "minLength": 1
        },
        "deterministic_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "semantic_intent_check": {
          "type": "string"
        }
      }
    },
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "actions"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "feedback_channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["after_action", "observes"],
        "properties": {
          "after_action": {
            "type": "string",
            "minLength": 1
          },
          "observes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "stop_escalate_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_iterations", "no_progress_after", "escalate_when"],
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "no_progress_after": {
          "type": "integer",
          "minimum": 1
        },
        "escalate_when": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "test_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mandatory_floor",
        "required_from_task_signals",
        "additive_agent_tests"
      ],
      "properties": {
        "mandatory_floor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/required_test"
          }
        },
        "required_from_task_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/required_test"
          }
        },
        "additive_agent_tests": {
          "const": true
        }
      }
    },
    "safe_bail_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "rollback", "idempotency"],
      "properties": {
        "state": {
          "type": "string",
          "minLength": 1
        },
        "rollback": {
          "type": "string",
          "minLength": 1
        },
        "idempotency": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "progress_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signals", "no_progress_rule"],
      "properties": {
        "signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "no_progress_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "control_channel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supports", "safe_checkpoint_required"],
      "properties": {
        "supports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["steer", "abort", "interrupt", "escalate"]
          }
        },
        "safe_checkpoint_required": {
          "type": "boolean"
        }
      }
    },
    "independent_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "evidence"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["golden_fixture", "external_command", "schema", "mutation", "agent_self_assessment"]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "redaction_posture": {
      "type": "string",
      "minLength": 1
    }
  },
  "definitions": {
    "required_test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command", "coverage_tags"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "signal": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "coverage_tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

