{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/spec-surface.schema.json",
  "title": "ADLC Specification Surface",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "surface_id",
    "owner",
    "enumerability",
    "capability_claims",
    "dimensions",
    "supported_combinations",
    "oracle_refs",
    "success_criteria",
    "unsupported_states",
    "out_of_scope",
    "redaction_posture"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "surface_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "enumerability": {
      "type": "object",
      "additionalProperties": true,
      "required": ["state", "rationale", "boundary_ref"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["enumerable", "bounded_with_exclusions"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "boundary_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "claim", "scope"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "minLength": 1},
          "limitations": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "values"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "supported_combinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "dimension_values", "oracle_refs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "dimension_values": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {"type": "string", "minLength": 1}
          },
          "oracle_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "oracle_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "description", "oracle_ref", "evaluation_type"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "oracle_ref": {"type": "string", "minLength": 1},
          "evaluation_type": {
            "type": "string",
            "enum": ["deterministic", "human_review_required"]
          }
        }
      }
    },
    "unsupported_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["state", "reason", "failure_action"],
        "properties": {
          "state": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "failure_action": {
            "type": "string",
            "enum": ["block", "pause", "escalate"]
          }
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "redaction_posture": {
      "type": "string",
      "minLength": 1
    }
  }
}
