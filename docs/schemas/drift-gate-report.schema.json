{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/drift-gate-report.schema.json",
  "title": "ADLC Drift Gate Report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "gate_id",
    "status",
    "surface_id",
    "oracle_id",
    "metrics",
    "summary",
    "next_action",
    "evidence_refs",
    "redaction_posture"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "gate_id": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "pause", "escalate"]},
    "surface_id": {"type": "string", "minLength": 1},
    "oracle_id": {"type": "string", "minLength": 1},
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "current", "threshold", "direction"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "current": {"type": "number"},
          "threshold": {"type": "number"},
          "direction": {"type": "string", "enum": ["max", "min", "trend"]}
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "regression_delta",
        "quality_trend_delta",
        "starvation_count",
        "no_work_count",
        "blocked_combinations",
        "oracle_coverage"
      ],
      "properties": {
        "regression_delta": {"type": "number"},
        "quality_trend_delta": {"type": "number"},
        "starvation_count": {"type": "integer", "minimum": 0},
        "no_work_count": {"type": "integer", "minimum": 0},
        "blocked_combinations": {"type": "integer", "minimum": 0},
        "oracle_coverage": {"type": "number", "minimum": 0}
      }
    },
    "next_action": {"type": "string", "minLength": 1},
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "redaction_posture": {"type": "string", "minLength": 1}
  }
}
