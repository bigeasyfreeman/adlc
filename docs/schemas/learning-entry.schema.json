{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/learning-entry.schema.json",
  "title": "ADLC Learning Entry Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "date",
    "adlc_domain",
    "problem_type",
    "module",
    "severity",
    "track",
    "tags",
    "related_tasks",
    "source_evidence",
    "verifier",
    "redaction_review",
    "stale_conditions"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "adlc_domain": {
      "type": "string",
      "enum": [
        "build_loop",
        "fix_loop",
        "feedback_loop",
        "integration",
        "security",
        "observability",
        "testing",
        "workflow",
        "other"
      ]
    },
    "problem_type": {
      "type": "string",
      "enum": [
        "bugfix",
        "build_validation",
        "lint_cleanup",
        "runtime_failure",
        "performance",
        "security",
        "workflow",
        "architecture",
        "convention",
        "tooling"
      ]
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ]
    },
    "track": {
      "type": "string",
      "enum": [
        "bugfix",
        "knowledge"
      ]
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "command",
        "expected"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "command",
            "test",
            "schema",
            "manual"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "redaction_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "needs_review"
          ]
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stale_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
