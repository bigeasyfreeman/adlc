{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/loop-test-result.schema.json",
  "title": "ADLC Loop Test Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "contract_id",
    "task_id",
    "results"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "runner": {
      "type": "string",
      "minLength": 1
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "required_test_id",
          "command",
          "exit_code",
          "runner",
          "artifact_refs"
        ],
        "properties": {
          "required_test_id": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer",
            "minimum": 0
          },
          "runner": {
            "type": "string",
            "minLength": 1
          },
          "artifact_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stdout_sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "stderr_sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "ended_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
