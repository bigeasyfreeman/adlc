{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/workflow-state.schema.json",
  "title": "ADLC Workflow State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "brief_id",
    "phase",
    "step",
    "status",
    "started_at",
    "updated_at",
    "checkpoint",
    "side_effects"
  ],
  "properties": {
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "start",
        "triage",
        "compound_preflight",
        "research",
        "plan",
        "plan_review",
        "intent_validation",
        "scaffold",
        "gen_tests",
        "context_assembly",
        "code",
        "code_review",
        "security",
        "qa",
        "test_strength",
        "slop_gate",
        "pr_prep",
        "learning_capture",
        "engineer_review",
        "fixer",
        "done",
        "escalate",
        "phase_0_codebase_research",
        "phase_0a_grafana_observability",
        "phase_1_brief_prefill",
        "phase_2_eval_council",
        "phase_3_scaffolding",
        "phase_4_failing_tests",
        "phase_5_codegen_context",
        "phase_6_parallel_codegen",
        "phase_7_security_review",
        "phase_8_task_breakdown",
        "phase_9_codegen_execution",
        "phase_10_jira_confluence_prep",
        "phase_11_ci_cd_qa_prep",
        "phase_12_deploy_gate",
        "phase_13_monitoring_feedback"
      ]
    },
    "step": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "awaiting_approval",
        "executing",
        "waiting_on_external",
        "completed",
        "failed"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "checkpoint": {
      "type": "object",
      "description": "Phase-specific checkpoint payload",
      "additionalProperties": true
    },
    "side_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idempotency_key",
          "tool_name",
          "operation",
          "status",
          "timestamp"
        ],
        "properties": {
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          },
          "brief_id": {
            "type": "string",
            "minLength": 1
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "operation": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "attempted",
              "deduplicated",
              "completed",
              "failed"
            ]
          },
          "artifact_id": {
            "type": "string"
          },
          "artifact_ref": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "resume_count": {
      "type": "integer",
      "minimum": 0
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "last_resumed_at": {
      "type": "string",
      "format": "date-time"
    },
    "task_fingerprints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "input_hash",
          "status",
          "primary_verifier"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "input_hash": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "completed",
              "failed",
              "skipped_already_satisfied"
            ]
          },
          "primary_verifier": {
            "type": "string",
            "minLength": 1
          },
          "pre_change_status": {
            "type": "string",
            "enum": [
              "failed_expected",
              "missing",
              "wrong_failure",
              "not_applicable"
            ]
          },
          "post_change_status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "changed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commit": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "interface_contract_status": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract_id",
          "status"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "missing",
              "draft",
              "ready",
              "blocked",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "productionization_status": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "coverage_state",
          "status"
        ],
        "properties": {
          "gate_id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "coverage_state": {
            "type": "string",
            "enum": [
              "unsupported",
              "evidence_only",
              "monitor_only",
              "not_yet_ga",
              "governed",
              "production_ready"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "blocked",
              "ready",
              "monitor",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "loop_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "iteration_count",
        "last_progress_signal",
        "last_observation",
        "evidence_refs"
      ],
      "properties": {
        "iteration_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_progress_signal": {
          "type": "string",
          "minLength": 1
        },
        "last_observation": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "no_progress_count": {
      "type": "integer",
      "minimum": 0
    },
    "control_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "event_type",
          "status",
          "reason",
          "timestamp"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "event_type": {
            "type": "string",
            "enum": [
              "steer",
              "abort",
              "interrupt",
              "escalate"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "applied",
              "deferred",
              "completed"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "safe_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "phase",
        "idempotent",
        "retryable",
        "rollback_plan"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "idempotent": {
          "type": "boolean"
        },
        "retryable": {
          "type": "boolean"
        },
        "rollback_plan": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "escalation_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "phase",
        "requested_decision",
        "context_refs"
      ],
      "properties": {
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "requested_decision": {
          "type": "string",
          "minLength": 1
        },
        "no_progress_after": {
          "type": "integer",
          "minimum": 0
        },
        "recent_observations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "context_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "work_item_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "external_id",
          "idempotency_key",
          "operation",
          "status",
          "updated_at"
        ],
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "github",
              "jira",
              "linear"
            ]
          },
          "external_id": {
            "type": "string",
            "minLength": 1
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          },
          "brief_id": {
            "type": "string",
            "minLength": 1
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "build_brief_id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_ref": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "operation": {
            "type": "string",
            "enum": [
              "find",
              "create",
              "update",
              "append",
              "noop",
              "escalate"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "created",
              "updated",
              "appended",
              "deduplicated",
              "failed",
              "blocked"
            ]
          },
          "last_sync_idempotency_key": {
            "type": "string",
            "minLength": 1
          },
          "status_update": {
            "type": "object",
            "additionalProperties": true
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "queue_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "queue_id",
          "task_id",
          "status",
          "updated_at"
        ],
        "properties": {
          "queue_id": {
            "type": "string",
            "minLength": 1
          },
          "queue_ref": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "agent_id": {
            "type": "string",
            "minLength": 1
          },
          "brief_id": {
            "type": "string",
            "minLength": 1
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "claimed",
              "running",
              "blocked",
              "done",
              "escalated",
              "released",
              "abandoned"
            ]
          },
          "expected_paths": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "kind"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "file",
                    "directory",
                    "glob"
                  ]
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "worktree_ref": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "worktree_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "branch",
          "path",
          "status",
          "updated_at"
        ],
        "properties": {
          "queue_id": {
            "type": "string",
            "minLength": 1
          },
          "queue_ref": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "branch": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "base_ref": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "prepared",
              "active",
              "cleanup_blocked",
              "cleaned",
              "abandoned"
            ]
          },
          "dirty": {
            "type": "boolean"
          },
          "cleanup_eligible": {
            "type": "boolean"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "phase_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase",
          "artifact_ref",
          "status",
          "updated_at"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "artifact_ref": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["planned", "pass", "fail", "blocked", "skipped"]
          },
          "label": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "stop_reason": {
            "type": "string",
            "minLength": 1
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "stop_reason": {
      "type": "string"
    },
    "budget_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decision", "evidence_refs"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "warning", "alert", "exhausted", "stale", "missing"]
        },
        "decision": {
          "type": "string",
          "enum": ["proceed", "warning", "wrap_up", "blocked", "not_evaluated"]
        },
        "token_budget_ref": {
          "type": "string",
          "minLength": 1
        },
        "projected_total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "budget_remaining": {
          "type": "integer",
          "minimum": 0
        },
        "threshold": {
          "type": "string",
          "enum": ["warn_at", "alert_at", "hard_stop_at", "artifact_status", "missing", "not_evaluated"]
        },
        "stop_reason": {
          "type": "string",
          "enum": ["budget_exhausted", "budget_stale", "budget_missing"]
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
