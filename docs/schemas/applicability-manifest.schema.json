{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/applicability-manifest.schema.json",
  "title": "ADLC Applicability Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "task_classification",
    "task_classification_confidence",
    "change_surface",
    "claim_provenance",
    "contamination",
    "section_policy",
    "verification_spec"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "task_classification": {
      "type": "string",
      "enum": [
        "feature",
        "bugfix",
        "build_validation",
        "lint_cleanup",
        "refactor",
        "infra",
        "docs",
        "security"
      ]
    },
    "task_classification_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "classification_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "change_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "new_attack_surface",
        "runtime_path_change",
        "service_boundary_change",
        "external_integration",
        "persistent_storage",
        "api_change",
        "data_format_change",
        "auth_change",
        "perf_sensitive",
        "user_facing_operation"
      ],
      "properties": {
        "new_attack_surface": {
          "type": "boolean"
        },
        "runtime_path_change": {
          "type": "boolean"
        },
        "service_boundary_change": {
          "type": "boolean"
        },
        "external_integration": {
          "type": "boolean"
        },
        "persistent_storage": {
          "type": "boolean"
        },
        "api_change": {
          "type": "boolean"
        },
        "data_format_change": {
          "type": "boolean"
        },
        "auth_change": {
          "type": "boolean"
        },
        "perf_sensitive": {
          "type": "boolean"
        },
        "user_facing_operation": {
          "type": "boolean"
        }
      }
    },
    "claim_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "unsupported",
        "contradicted"
      ],
      "properties": {
        "supported": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/claim_record"
          }
        },
        "unsupported": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/claim_record"
          }
        },
        "contradicted": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/claim_record"
          }
        }
      }
    },
    "contamination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flags",
        "supported_claims",
        "unsupported_claims",
        "contradicted_claims",
        "needs_clarification",
        "suspect_phrases"
      ],
      "properties": {
        "flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "unsupported_claim",
              "contradiction",
              "scope_creep",
              "ambiguous_term",
              "missing_owner"
            ]
          }
        },
        "supported_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unsupported_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contradicted_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "needs_clarification": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "suspect_phrases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "section_policy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_name",
          "status",
          "reason"
        ],
        "properties": {
          "section_name": {
            "type": "string",
            "enum": [
              "1_context",
              "2_scope_and_constraints",
              "3_repo_findings",
              "4_architecture",
              "5_security_review",
              "6_observability_slo",
              "7_execution_plan",
              "8_task_tickets",
              "9_risks",
              "10_rollout",
              "11_validation_plan",
              "12_skill_trigger_configuration"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "suppressed",
              "not_applicable"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "trigger_fields": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "overridden_by": {
            "type": "string",
            "enum": ["section_policy_judge"]
          }
        }
      }
    },
    "verification_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_verifier",
        "must_fail_before_change",
        "must_be_deterministic",
        "scope_note"
      ],
      "properties": {
        "primary_verifier": {
          "$ref": "#/definitions/verifier"
        },
        "secondary_verifiers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/verifier"
          }
        },
        "must_fail_before_change": {
          "type": "boolean"
        },
        "must_be_deterministic": {
          "type": "boolean"
        },
        "scope_note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "definitions": {
    "claim_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "source_ref",
        "extracted_from"
      ],
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "extracted_from": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "target",
        "expected_pre_change",
        "expected_post_change"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "test",
            "command",
            "reproducer"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "expected_pre_change": {
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        "expected_post_change": {
          "type": "string",
          "enum": [
            "pass"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "target_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_failure_mode": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
