{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/work-item-sync.schema.json",
  "title": "ADLC Work Item Sync",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "target",
    "work_item",
    "run_identity",
    "status_update"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "enum": [
        "1.0.0"
      ]
    },
    "target": {
      "type": "string",
      "enum": [
        "github",
        "jira",
        "linear"
      ]
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_id",
        "idempotency_key",
        "title"
      ],
      "properties": {
        "external_id": {
          "type": "string",
          "minLength": 1
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        },
        "build_brief_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "run_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "brief_id",
        "run_id",
        "session_id"
      ],
      "properties": {
        "brief_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "resume_count": {
          "type": "integer",
          "minimum": 0
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "status_update": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "phase",
        "evidence_refs",
        "next_action"
      ],
      "properties": {
        "update_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "executing",
            "waiting_on_external",
            "blocked",
            "completed",
            "failed",
            "needs_human"
          ]
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "summary"
            ],
            "properties": {
              "code": {
                "type": "string",
                "minLength": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "verifier_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status",
              "evidence_refs"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail",
                  "not_run",
                  "blocked"
                ]
              },
              "summary": {
                "type": "string"
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "stop_reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
