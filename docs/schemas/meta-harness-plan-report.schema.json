{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/meta-harness-plan-report.schema.json",
  "title": "ADLC Meta-Harness Plan Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "status",
    "dry_run",
    "autonomy_claim",
    "workspace",
    "run_identity",
    "sources",
    "candidates",
    "selected",
    "planned_actions",
    "generated_artifacts",
    "boundary",
    "summary",
    "issues",
    "evidence_refs"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "enum": ["1.0.0"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "blocked"]
    },
    "dry_run": {
      "type": "boolean",
      "enum": [true]
    },
    "autonomy_claim": {
      "type": "string",
      "enum": ["bounded_meta_harness_plan"]
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "run_identity": {
      "$ref": "#/definitions/run_identity"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/source"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/candidate"
      }
    },
    "selected": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/candidate"
      }
    },
    "planned_actions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/planned_action"
      }
    },
    "generated_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["work_queue_seed", "work_item_syncs", "validation"],
      "properties": {
        "work_queue_seed": {
          "type": "object"
        },
        "work_item_syncs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "validation": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/artifact_validation"
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["does_not", "requires_human_approval", "execution_contract"],
      "properties": {
        "does_not": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requires_human_approval": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "execution_contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_count",
        "selected_count",
        "admitted_count",
        "needs_human_count",
        "planned_action_count",
        "issues"
      ],
      "properties": {
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "selected_count": {
          "type": "integer",
          "minimum": 0
        },
        "admitted_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_human_count": {
          "type": "integer",
          "minimum": 0
        },
        "planned_action_count": {
          "type": "integer",
          "minimum": 0
        },
        "issues": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/issue"
      }
    },
    "state_path": {
      "type": "string",
      "minLength": 1
    },
    "output_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "definitions": {
    "run_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["brief_id", "run_id", "session_id"],
      "properties": {
        "brief_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "resume_count": {
          "type": "integer",
          "minimum": 0
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "path_owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["file", "directory", "glob"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "risk", "verifiability", "repeatability", "urgency", "total"],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "risk": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "verifiability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "repeatability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "urgency": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "total": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "summary"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "queue_task_id",
        "title",
        "summary",
        "source",
        "queue_source_type",
        "selected_template_id",
        "selected_template_title",
        "decision",
        "scores",
        "reasons",
        "blockers",
        "expected_paths",
        "verifier_refs"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "queue_task_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/definitions/source"
        },
        "queue_source_type": {
          "type": "string",
          "minLength": 1
        },
        "selected_template_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_template_title": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": ["admit_to_queue", "needs_human"]
        },
        "scores": {
          "$ref": "#/definitions/scores"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/blocker"
          }
        },
        "expected_paths": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/path_owner"
          }
        },
        "verifier_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "work_item_external_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "planned_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "candidate_id",
        "template_id",
        "type",
        "command",
        "requires_admission",
        "human_gate",
        "status"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "loop_template_install",
            "work_item_sync",
            "queue_claim",
            "worktree_prepare",
            "deterministic_verifier",
            "human_review"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "requires_admission": {
          "type": "boolean"
        },
        "human_gate": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "blocked"]
        }
      }
    },
    "artifact_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_type", "schema_alias", "valid", "errors"],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": ["work_queue_seed", "work_item_sync"]
        },
        "schema_alias": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "valid": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["severity", "rule", "message"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "blocking"]
        },
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
