{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/ponytail-admission-report.schema.json",
  "title": "ADLC Ponytail Admission Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "status",
    "build_brief_id",
    "tasks",
    "issues",
    "summary",
    "boundary"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "blocked"
      ]
    },
    "build_brief_id": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "artifact_type",
          "executable",
          "status",
          "minimality_contract",
          "issues"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "type": "string",
            "minLength": 1
          },
          "executable": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "blocked",
              "not_applicable"
            ]
          },
          "minimality_contract": {
            "oneOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "issues": {
            "$ref": "#/definitions/issues"
          }
        }
      }
    },
    "issues": {
      "$ref": "#/definitions/issues"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tasks",
        "executable_tasks",
        "passed",
        "blocked",
        "issues"
      ],
      "properties": {
        "tasks": {
          "type": "integer",
          "minimum": 0
        },
        "executable_tasks": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "issues": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not"
      ],
      "properties": {
        "does_not": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "definitions": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "rule",
          "task_id",
          "message"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "blocking"
            ]
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
