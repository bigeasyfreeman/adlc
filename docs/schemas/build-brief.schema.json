{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/build-brief.schema.json",
  "title": "ADLC Build Brief Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "brief_id",
    "prd_id",
    "applicability_manifest",
    "sections"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "prd_id": {
      "type": "string",
      "minLength": 1
    },
    "applicability_manifest": {
      "$ref": "applicability-manifest.schema.json"
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "1_context",
        "2_scope_and_constraints",
        "3_repo_findings",
        "4_architecture",
        "5_security_review",
        "6_observability_slo",
        "7_execution_plan",
        "8_task_tickets",
        "9_risks",
        "10_rollout",
        "11_validation_plan",
        "12_skill_trigger_configuration"
      ],
      "properties": {
        "1_context": {
          "type": "string"
        },
        "2_scope_and_constraints": {
          "type": "string"
        },
        "3_repo_findings": {
          "type": "string"
        },
        "4_architecture": {
          "type": "string"
        },
        "5_security_review": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "6_observability_slo": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "7_execution_plan": {
          "type": "string"
        },
        "8_task_tickets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/task"
          }
        },
        "9_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "10_rollout": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "11_validation_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "12_skill_trigger_configuration": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "title",
        "objective",
        "task_classification",
        "scope",
        "out_of_scope",
        "dependencies",
        "acceptance_criteria",
        "anti_slop_rules",
        "implementation_notes",
        "verification_spec",
        "failure_modes",
        "bpe_classification",
        "owner",
        "files_to_modify",
        "files_to_create",
        "reference_impl"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^[A-Z0-9_-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "task_classification": {
          "type": "string",
          "enum": [
            "feature",
            "bugfix",
            "build_validation",
            "lint_cleanup",
            "refactor",
            "infra",
            "docs",
            "security"
          ]
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "given",
                  "when",
                  "then"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^AC-[A-Z0-9_-]+$"
                  },
                  "given": {
                    "type": "string",
                    "minLength": 1
                  },
                  "when": {
                    "type": "string",
                    "minLength": 1
                  },
                  "then": {
                    "type": "string",
                    "minLength": 1
                  },
                  "measurable_post_condition": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "anti_slop_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_spec": {
          "$ref": "#/definitions/verification_spec"
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observability": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bpe_classification": {
          "type": "string",
          "enum": [
            "type_1",
            "type_2"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "files_to_modify": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_to_create": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_impl": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verification_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_verifier",
        "must_fail_before_change",
        "must_be_deterministic",
        "scope_note"
      ],
      "properties": {
        "primary_verifier": {
          "$ref": "#/definitions/verifier"
        },
        "secondary_verifiers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/verifier"
          }
        },
        "must_fail_before_change": {
          "type": "boolean"
        },
        "must_be_deterministic": {
          "type": "boolean"
        },
        "scope_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "target",
        "expected_pre_change",
        "expected_post_change"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "test",
            "command",
            "reproducer"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "expected_pre_change": {
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        "expected_post_change": {
          "type": "string",
          "enum": [
            "pass"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "target_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_failure_mode": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
