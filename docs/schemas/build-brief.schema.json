{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/build-brief.schema.json",
  "title": "ADLC Build Brief Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "brief_id",
    "prd_id",
    "sections"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "prd_id": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "1_context",
        "2_scope_and_constraints",
        "3_repo_findings",
        "4_architecture",
        "5_security_review",
        "6_observability_slo",
        "7_execution_plan",
        "8_task_tickets",
        "9_risks",
        "10_rollout",
        "11_validation_plan",
        "12_skill_trigger_configuration"
      ],
      "properties": {
        "1_context": {
          "type": "string"
        },
        "2_scope_and_constraints": {
          "type": "string"
        },
        "3_repo_findings": {
          "type": "string"
        },
        "4_architecture": {
          "type": "string"
        },
        "5_security_review": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "6_observability_slo": {
          "type": "string"
        },
        "7_execution_plan": {
          "type": "string"
        },
        "8_task_tickets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/task"
          }
        },
        "9_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "10_rollout": {
          "type": "string"
        },
        "11_validation_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "12_skill_trigger_configuration": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "title",
        "objective",
        "scope",
        "out_of_scope",
        "dependencies",
        "acceptance_criteria",
        "implementation_notes",
        "contracts",
        "failure_modes",
        "observability",
        "tests",
        "security_impact",
        "bpe_classification",
        "owner"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^[A-Z0-9_-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observability": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bpe_classification": {
          "type": "string",
          "enum": [
            "type_1",
            "type_2"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
