{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/build-brief.schema.json",
  "title": "ADLC Build Brief Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "adlc_mode",
    "brief_id",
    "prd_id",
    "applicability_manifest",
    "enterprise_readiness_contract",
    "sections"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "adlc_mode": {
      "type": "string",
      "enum": [
        "prd_only",
        "decompose_only",
        "prd_and_decompose"
      ]
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "prd_id": {
      "type": "string",
      "minLength": 1
    },
    "narrative_contract": {
      "type": "object",
      "description": "Human-readable intent and impact for this Build Brief. Populated by planner from PRD + intent_validation human gate. Emitted as ## Narrative at the top of every work-item description at contract_version >= 1.1.x.",
      "additionalProperties": false,
      "required": ["product_feature", "feature", "value", "why", "goal"],
      "properties": {
        "product_feature": {
          "type": "string",
          "description": "3-6 sentence tight narrative connecting this ticket to the larger product feature it builds toward. Names the product feature, why it matters, and what this ticket specifically contributes. Founder voice.",
          "minLength": 1
        },
        "feature": {
          "type": "string",
          "description": "One sentence - what this is concretely.",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "description": "One sentence - what the user gets, in user language.",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "description": "2-3 sentences - the problem this solves, in plain language. No ADLC jargon.",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "description": "One sentence - what success looks like, observably.",
          "minLength": 1
        },
        "human_validated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO8601 timestamp from intent_validation phase. REQUIRED at contract_version >= 1.1.x."
        },
        "human_validator": {
          "type": "string",
          "description": "Name of the human who approved the narrative at the intent_validation gate."
        }
      }
    },
    "enterprise_readiness_contract": {
      "$ref": "#/definitions/enterprise_readiness_contract"
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "1_context",
        "2_scope_and_constraints",
        "3_repo_findings",
        "4_architecture",
        "5_security_review",
        "6_observability_slo",
        "7_execution_plan",
        "8_task_tickets",
        "9_risks",
        "10_rollout",
        "11_validation_plan",
        "12_skill_trigger_configuration"
      ],
      "properties": {
        "1_context": {
          "type": "string"
        },
        "2_scope_and_constraints": {
          "type": "string"
        },
        "3_repo_findings": {
          "type": "string"
        },
        "4_architecture": {
          "type": "string"
        },
        "5_security_review": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "6_observability_slo": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "7_execution_plan": {
          "type": "string"
        },
        "8_task_tickets": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/definitions/task"
          }
        },
        "9_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "10_rollout": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "11_validation_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "12_skill_trigger_configuration": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "13_comprehension_context": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "14_graph_research_evidence": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "15_dark_code_risk": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "16_implementation_interfaces": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/implementation_interface_contract"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "17_productionization_gates": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/productionization_gate"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "applicability_manifest": {
      "$ref": "applicability-manifest.schema.json"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "adlc_mode": {
            "enum": [
              "decompose_only",
              "prd_and_decompose"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "enterprise_readiness_contract": {
            "properties": {
              "validation_tasks": {
                "minItems": 1
              }
            }
          },
          "sections": {
            "properties": {
              "8_task_tickets": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "version": {
            "pattern": "^(?:1\\.(?:[1-9]\\d*)\\.(?:0|[1-9]\\d*)|(?:[2-9]|[1-9]\\d{1,})\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*))$"
          }
        }
      },
      "then": {
        "required": [
          "narrative_contract"
        ],
        "properties": {
          "narrative_contract": {
            "required": [
              "product_feature",
              "feature",
              "value",
              "why",
              "goal",
              "human_validated_at"
            ]
          }
        }
      }
    }
  ],
  "definitions": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "task_id",
        "title",
        "objective",
        "task_classification",
        "decision_contract",
        "scope",
        "out_of_scope",
        "dependencies",
        "acceptance_criteria",
        "anti_slop_rules",
        "tech_debt_boundaries",
        "compatibility_contract",
        "implementation_notes",
        "verification_spec",
        "evidence_responsibilities",
        "definition_of_done",
        "failure_modes",
        "bpe_classification",
        "owner",
        "files_to_modify",
        "files_to_create",
        "reference_impl"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": [
            "scope_lock_epic",
            "decision_gate",
            "implementation_task",
            "validation_task"
          ]
        },
        "task_id": {
          "type": "string",
          "pattern": "^[A-Z0-9_-]+$"
        },
        "stable_task_identity": {
          "$ref": "#/definitions/stable_task_identity"
        },
        "resume_fingerprint": {
          "$ref": "#/definitions/resume_fingerprint"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "task_classification": {
          "type": "string",
          "enum": [
            "feature",
            "bugfix",
            "build_validation",
            "lint_cleanup",
            "refactor",
            "infra",
            "docs",
            "security"
          ]
        },
        "decision_contract": {
          "$ref": "#/definitions/decision_contract"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "given",
                  "when",
                  "then"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^AC-[A-Z0-9_-]+$"
                  },
                  "given": {
                    "type": "string",
                    "minLength": 1
                  },
                  "when": {
                    "type": "string",
                    "minLength": 1
                  },
                  "then": {
                    "type": "string",
                    "minLength": 1
                  },
                  "measurable_post_condition": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "anti_slop_rules": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "$ref": "#/definitions/not_applicable_reason"
            }
          ]
        },
        "tech_debt_boundaries": {
          "$ref": "#/definitions/tech_debt_boundaries"
        },
        "compatibility_contract": {
          "$ref": "#/definitions/compatibility_contract"
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_spec": {
          "$ref": "#/definitions/verification_spec"
        },
        "evidence_responsibilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observability": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bpe_classification": {
          "type": "string",
          "enum": [
            "type_1",
            "type_2"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "files_to_modify": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_to_create": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_impl": {
          "type": "string",
          "minLength": 1
        },
        "work_item_metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "area": {
              "type": "string",
              "minLength": 1
            },
            "area_label": {
              "type": "string",
              "minLength": 1
            },
            "phase_label": {
              "type": "string",
              "minLength": 1
            },
            "target_project": {
              "type": "string",
              "minLength": 1
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "external_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "loop_contract_path": {
              "type": "string",
              "minLength": 1
            },
            "loop_action_path": {
              "type": "string",
              "minLength": 1
            },
            "loop_maturity_report_path": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "comprehension_context_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compatibility_evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dark_code_hotspots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "construct_map_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "paved_road_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "intent_contract_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "production_invariant_coverage": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "invariant",
              "status",
              "evidence"
            ],
            "properties": {
              "invariant": {
                "type": "string",
                "enum": [
                  "identity",
                  "auth",
                  "tenancy",
                  "data_integrity",
                  "persistence",
                  "ordering",
                  "idempotency",
                  "retries",
                  "sensitive_data",
                  "migration",
                  "downgrade",
                  "observability",
                  "dependency_failure",
                  "other"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "covered",
                  "not_applicable",
                  "gap",
                  "requires_human_judgment"
                ]
              },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "implementation_interface_contract": {
          "$ref": "#/definitions/implementation_interface_contract"
        },
        "productionization_gate": {
          "$ref": "#/definitions/productionization_gate"
        },
        "slop_quality_gate": {
          "$ref": "#/definitions/slop_quality_gate"
        },
        "generated_output_surface": {
          "$ref": "#/definitions/generated_output_surface"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "implementation_task"
              }
            }
          },
          "then": {
            "properties": {
              "decision_contract": {
                "properties": {
                  "status": {
                    "enum": [
                      "not_applicable",
                      "resolved"
                    ]
                  },
                  "blocks_implementation": {
                    "const": false
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "scope_lock_epic"
              }
            }
          },
          "then": {
            "properties": {
              "files_to_modify": {
                "maxItems": 0
              },
              "files_to_create": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "decision_gate"
              }
            }
          },
          "then": {
            "properties": {
              "bpe_classification": {
                "const": "type_1"
              },
              "decision_contract": {
                "properties": {
                  "type1_decision": {
                    "const": true
                  },
                  "status": {
                    "const": "unresolved"
                  },
                  "blocks_implementation": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "validation_task"
              }
            }
          },
          "then": {
            "properties": {
              "task_classification": {
                "const": "build_validation"
              },
              "decision_contract": {
                "properties": {
                  "blocks_implementation": {
                    "const": false
                  }
                }
              }
            }
          }
        }
      ]
    },
    "enterprise_readiness_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_grade_target",
        "backward_compatibility",
        "forward_compatibility",
        "failure_mode_coverage",
        "definition_of_done",
        "validation_tasks",
        "compliance_posture"
      ],
      "properties": {
        "production_grade_target": {
          "type": "string",
          "minLength": 1
        },
        "backward_compatibility": {
          "type": "string",
          "minLength": 1
        },
        "forward_compatibility": {
          "type": "string",
          "minLength": 1
        },
        "failure_mode_coverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validation_tasks": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compliance_posture": {
          "type": "string",
          "minLength": 1
        },
        "construct_map_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "paved_road_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "production_invariant_coverage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "implementation_interface_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "productionization_gate_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decision_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type1_decision",
        "status",
        "owner",
        "deadline",
        "blocks_implementation",
        "resolution"
      ],
      "properties": {
        "type1_decision": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_applicable",
            "unresolved",
            "resolved"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "deadline": {
          "type": "string",
          "minLength": 1
        },
        "blocks_implementation": {
          "type": "boolean"
        },
        "resolution": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tech_debt_boundaries": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "prerequisite_debt",
            "deferred_debt",
            "deferral_safety"
          ],
          "properties": {
            "prerequisite_debt": {
              "type": "string",
              "minLength": 1
            },
            "deferred_debt": {
              "type": "string",
              "minLength": 1
            },
            "deferral_safety": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "$ref": "#/definitions/not_applicable_reason"
        }
      ]
    },
    "compatibility_contract": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "backward",
            "forward",
            "migration_or_rollout"
          ],
          "properties": {
            "backward": {
              "type": "string",
              "minLength": 1
            },
            "forward": {
              "type": "string",
              "minLength": 1
            },
            "migration_or_rollout": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "$ref": "#/definitions/not_applicable_reason"
        }
      ]
    },
    "verification_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_verifier",
        "must_fail_before_change",
        "must_be_deterministic",
        "scope_note"
      ],
      "properties": {
        "primary_verifier": {
          "$ref": "#/definitions/verifier"
        },
        "secondary_verifiers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/verifier"
          }
        },
        "must_fail_before_change": {
          "type": "boolean"
        },
        "must_be_deterministic": {
          "type": "boolean"
        },
        "scope_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "not_applicable_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicability",
        "reason"
      ],
      "properties": {
        "applicability": {
          "const": "not_applicable"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "implementation_interface_contract": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "reuse",
            "consumes",
            "emits",
            "minimum_fields",
            "invariants",
            "integration_points",
            "validation_gates"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "capability": {
              "type": "string",
              "minLength": 1
            },
            "task_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "reuse": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "consumes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
