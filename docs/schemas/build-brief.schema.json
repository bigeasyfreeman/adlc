{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/bigeasyfreeman/adlc/blob/main/docs/schemas/build-brief.schema.json",
  "title": "ADLC Build Brief Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "adlc_mode",
    "brief_id",
    "prd_id",
    "applicability_manifest",
    "enterprise_readiness_contract",
    "sections"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "adlc_mode": {
      "type": "string",
      "enum": [
        "prd_only",
        "decompose_only",
        "prd_and_decompose"
      ]
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "prd_id": {
      "type": "string",
      "minLength": 1
    },
    "enterprise_readiness_contract": {
      "$ref": "#/definitions/enterprise_readiness_contract"
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "1_context",
        "2_scope_and_constraints",
        "3_repo_findings",
        "4_architecture",
        "5_security_review",
        "6_observability_slo",
        "7_execution_plan",
        "8_task_tickets",
        "9_risks",
        "10_rollout",
        "11_validation_plan",
        "12_skill_trigger_configuration"
      ],
      "properties": {
        "1_context": {
          "type": "string"
        },
        "2_scope_and_constraints": {
          "type": "string"
        },
        "3_repo_findings": {
          "type": "string"
        },
        "4_architecture": {
          "type": "string"
        },
        "5_security_review": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "6_observability_slo": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "7_execution_plan": {
          "type": "string"
        },
        "8_task_tickets": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/definitions/task"
          }
        },
        "9_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "10_rollout": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "11_validation_plan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "12_skill_trigger_configuration": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "applicability_manifest": {
      "$ref": "applicability-manifest.schema.json"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "adlc_mode": {
            "enum": [
              "decompose_only",
              "prd_and_decompose"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "enterprise_readiness_contract": {
            "properties": {
              "validation_tasks": {
                "minItems": 1
              }
            }
          },
          "sections": {
            "properties": {
              "8_task_tickets": {
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "task_id",
        "title",
        "objective",
        "task_classification",
        "decision_contract",
        "scope",
        "out_of_scope",
        "dependencies",
        "acceptance_criteria",
        "anti_slop_rules",
        "tech_debt_boundaries",
        "compatibility_contract",
        "implementation_notes",
        "verification_spec",
        "evidence_responsibilities",
        "definition_of_done",
        "failure_modes",
        "bpe_classification",
        "owner",
        "files_to_modify",
        "files_to_create",
        "reference_impl"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": [
            "scope_lock_epic",
            "decision_gate",
            "implementation_task",
            "validation_task"
          ]
        },
        "task_id": {
          "type": "string",
          "pattern": "^[A-Z0-9_-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "task_classification": {
          "type": "string",
          "enum": [
            "feature",
            "bugfix",
            "build_validation",
            "lint_cleanup",
            "refactor",
            "infra",
            "docs",
            "security"
          ]
        },
        "decision_contract": {
          "$ref": "#/definitions/decision_contract"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "given",
                  "when",
                  "then"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^AC-[A-Z0-9_-]+$"
                  },
                  "given": {
                    "type": "string",
                    "minLength": 1
                  },
                  "when": {
                    "type": "string",
                    "minLength": 1
                  },
                  "then": {
                    "type": "string",
                    "minLength": 1
                  },
                  "measurable_post_condition": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "anti_slop_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tech_debt_boundaries": {
          "$ref": "#/definitions/tech_debt_boundaries"
        },
        "compatibility_contract": {
          "$ref": "#/definitions/compatibility_contract"
        },
        "implementation_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_spec": {
          "$ref": "#/definitions/verification_spec"
        },
        "evidence_responsibilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "observability": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bpe_classification": {
          "type": "string",
          "enum": [
            "type_1",
            "type_2"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "files_to_modify": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_to_create": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reference_impl": {
          "type": "string",
          "minLength": 1
        },
        "work_item_metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "area": {
              "type": "string",
              "minLength": 1
            },
            "area_label": {
              "type": "string",
              "minLength": 1
            },
            "phase_label": {
              "type": "string",
              "minLength": 1
            },
            "target_project": {
              "type": "string",
              "minLength": 1
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "external_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "implementation_task"
              }
            }
          },
          "then": {
            "properties": {
              "decision_contract": {
                "properties": {
                  "status": {
                    "enum": [
                      "not_applicable",
                      "resolved"
                    ]
                  },
                  "blocks_implementation": {
                    "const": false
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "scope_lock_epic"
              }
            }
          },
          "then": {
            "properties": {
              "files_to_modify": {
                "maxItems": 0
              },
              "files_to_create": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "decision_gate"
              }
            }
          },
          "then": {
            "properties": {
              "bpe_classification": {
                "const": "type_1"
              },
              "decision_contract": {
                "properties": {
                  "type1_decision": {
                    "const": true
                  },
                  "status": {
                    "const": "unresolved"
                  },
                  "blocks_implementation": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_type": {
                "const": "validation_task"
              }
            }
          },
          "then": {
            "properties": {
              "task_classification": {
                "const": "build_validation"
              },
              "decision_contract": {
                "properties": {
                  "blocks_implementation": {
                    "const": false
                  }
                }
              }
            }
          }
        }
      ]
    },
    "enterprise_readiness_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_grade_target",
        "backward_compatibility",
        "forward_compatibility",
        "failure_mode_coverage",
        "definition_of_done",
        "validation_tasks",
        "compliance_posture"
      ],
      "properties": {
        "production_grade_target": {
          "type": "string",
          "minLength": 1
        },
        "backward_compatibility": {
          "type": "string",
          "minLength": 1
        },
        "forward_compatibility": {
          "type": "string",
          "minLength": 1
        },
        "failure_mode_coverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validation_tasks": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "compliance_posture": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "decision_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type1_decision",
        "status",
        "owner",
        "deadline",
        "blocks_implementation",
        "resolution"
      ],
      "properties": {
        "type1_decision": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_applicable",
            "unresolved",
            "resolved"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "deadline": {
          "type": "string",
          "minLength": 1
        },
        "blocks_implementation": {
          "type": "boolean"
        },
        "resolution": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tech_debt_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prerequisite_debt",
        "deferred_debt",
        "deferral_safety"
      ],
      "properties": {
        "prerequisite_debt": {
          "type": "string",
          "minLength": 1
        },
        "deferred_debt": {
          "type": "string",
          "minLength": 1
        },
        "deferral_safety": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibility_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backward",
        "forward",
        "migration_or_rollout"
      ],
      "properties": {
        "backward": {
          "type": "string",
          "minLength": 1
        },
        "forward": {
          "type": "string",
          "minLength": 1
        },
        "migration_or_rollout": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verification_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_verifier",
        "must_fail_before_change",
        "must_be_deterministic",
        "scope_note"
      ],
      "properties": {
        "primary_verifier": {
          "$ref": "#/definitions/verifier"
        },
        "secondary_verifiers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/verifier"
          }
        },
        "must_fail_before_change": {
          "type": "boolean"
        },
        "must_be_deterministic": {
          "type": "boolean"
        },
        "scope_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "target",
        "expected_pre_change",
        "expected_post_change",
        "target_files",
        "expected_failure_mode"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "test",
            "command",
            "reproducer"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "expected_pre_change": {
          "type": "string",
          "enum": [
            "fail"
          ]
        },
        "expected_post_change": {
          "type": "string",
          "enum": [
            "pass"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "target_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_failure_mode": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
